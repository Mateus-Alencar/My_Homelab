                <mxCell id="2" value="TLS / HTTPS" style="text;html=1;fontSize=24;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="20" width="200" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="3" value="1. Cliente acessa URL&#xa;https://site.com" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="120" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="4" value="2. DNS resolve domínio&#xa;→ IP do servidor" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="260" y="120" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="5" value="3.&amp;nbsp;O cliente envia para o servidor:&lt;br&gt;- Versão TLS&lt;br&gt;- Cipher Suites (Lista de alg.)&lt;br&gt;- Número aleatório (Random)" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="470" y="120" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="4.&amp;nbsp;O servidor responde com&lt;br&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;- Versão do TLS utilizada&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;- Número aleatório (Random)&lt;/span&gt;- Certificado TLS&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="700" y="120" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="5. Validação do Certificado&#xa;- CA confiável&#xa;- Validade&#xa;- Domínio" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="715" y="250" width="170" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="8" value="6. Troca de chaves (Key Exchange)&lt;br&gt;- O cliente e servidor usam algoritmos como ECDHE/RSA&lt;br&gt;- Geram uma sessão" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="470" y="250" width="220" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="9" value="7. Canal seguro estabelecido&#xa;(Handshake concluído)" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="255" y="250" width="190" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="10" value="8. Comunicação HTTPS&#xa;- Dados criptografados&#xa;- Integridade + confidencialidade" style="rounded=1;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="50" y="250" width="180" height="100" as="geometry"/>
                </mxCell>
